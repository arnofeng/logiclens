{
  "name": "logiclens",
  "version": "0.1.1-beta.8",
  "description": "Supercharge AI coding agents with multi-repository semantic dependency, contract tracing, and change impact analysis • local-first.",
  "type": "module",
  "bin": {
    "logiclens": "./bin/logiclens.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./plugins": {
      "types": "./dist/plugins/index.d.ts",
      "default": "./dist/plugins/index.js"
    },
    "./plugins/helpers": {
      "types": "./dist/plugins/helpers.d.ts",
      "default": "./dist/plugins/helpers.js"
    }
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "README-ZH.md"
  ],
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "build:prod": "npm run clean && tsc -p tsconfig.prod.json",
    "clean": "tsx scripts/clean.ts",
    "dev": "tsx src/cli.ts",
    "bench:scale": "tsx scripts/benchmark-scale.ts",
    "prepack": "npm run build",
    "test": "tsx scripts/test.ts",
    "typecheck": "tsc --noEmit",
    "audit:prod": "npm audit --omit=dev --audit-level=high --registry=https://registry.npmjs.org"
  },
  "keywords": [
    "codegraph",
    "kuzu",
    "tree-sitter"
  ],
  "author": "LogicLens contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arnofeng/logiclens.git"
  },
  "bugs": {
    "url": "https://github.com/arnofeng/logiclens/issues"
  },
  "homepage": "https://github.com/arnofeng/logiclens#readme",
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vue/compiler-sfc": "^3.5.38",
    "chromadb": "^3.4.3",
    "commander": "^15.0.0",
    "fast-glob": "^3.3.3",
    "ignore": "^7.0.5",
    "jsonc-parser": "^3.3.1",
    "kuzu": "^0.11.2",
    "openai": "^6.44.0",
    "pino": "^10.3.1",
    "tree-sitter": "^0.21.1",
    "tree-sitter-go": "^0.23.4",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-javascript": "^0.21.4",
    "tree-sitter-python": "^0.23.4",
    "tree-sitter-typescript": "^0.23.2",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "tar": "^7.5.16"
  }
}
